{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Каталог продукции"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "required": true
    },
    "Slug": {
      "type": "uid",
      "targetField": "Title",
      "required": true
    },
    "Short_Description": {
      "type": "text"
    },
    "Price_Rub": {
      "type": "decimal"
    },
    "Unit_of_Measure": {
      "type": "string"
    },
    "Weight": {
      "type": "string"
    },
    "Image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "Gallery": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images", "videos"]
    },
    "Full_Description": {
      "type": "richtext"
    },
    "Specs": {
      "type": "json"
    },
    "isFeatured": {
      "type": "boolean",
      "default": false
    },
    "isCustomOrder": {
      "type": "boolean",
      "default": false
    },
    "priceTiers": {
      "type": "component",
      "repeatable": true,
      "component": "shared.price-tier"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::product-category.product-category",
      "inversedBy": "products"
    },
    "Related_Products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product"
    },
    "reviews": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::review.review",
      "mappedBy": "product"
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
