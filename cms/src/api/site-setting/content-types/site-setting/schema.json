    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "contacts": {
      "type": "component",
      "repeatable": false,
      "component": "shared.contact-info"
    },
    "copyright": {
      "type": "string",
      "default": "Новтекас. Все права защищены."
    },
    "heroVideo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["videos"]
    },
    "heroPoster": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    }
  }
}
