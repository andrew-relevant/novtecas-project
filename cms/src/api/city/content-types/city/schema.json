    "namePrepositional": {
      "type": "string"
    },
    "nameDative": {
      "type": "string"
    },
    "phones": {
      "type": "json"
    },
    "postalCode": {
      "type": "string"
    },
    "address": {
      "type": "text"
    },
    "warehouseAddress": {
      "type": "text"
    },
    "mapLat": {
      "type": "float"
    },
    "mapLng": {
      "type": "float"
    },
    "sortOrder": {
      "type": "integer",
      "default": 500
    },
    "isDefault": {
      "type": "boolean",
      "default": false
    }
